# === Server ===
PORT=3000
NODE_ENV=development

# Comma-separated list of allowed frontend origins (CORS)
CLIENT_ORIGINS=http://localhost:5173

# === Auth secrets ===
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=replace-me
JWT_REFRESH_SECRET=replace-me
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d

# === Admin ===
ADMIN_KEY=replace-me

# === Google OAuth ===
# Create an OAuth 2.0 Client ID (Web application) at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=

# === Database ===
# Leave BOTH blank for local dev (uses a local SQLite file: server/finance.db).
# In production set these to your Turso database (https://turso.tech):
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
